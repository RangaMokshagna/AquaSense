# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────
# Local:  mongodb://localhost:27017/aquasense
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/aquasense
MONGODB_URI=mongodb://localhost:27017/aquasense

# ─── ML Service (Python FastAPI) ──────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── MQTT Broker (IoT Sensors) ────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_SENSORS=aquasense/sensors/#
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── API Security ─────────────────────────────────
API_KEY=your-secret-api-key-here

# ─── Alert Thresholds (defaults, overrideable via DB) ──
DEFAULT_PH_MIN=6.5
DEFAULT_PH_MAX=8.5
DEFAULT_TURBIDITY_MAX=4.0
DEFAULT_TEMP_MIN=10
DEFAULT_TEMP_MAX=35
