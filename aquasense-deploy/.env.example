# ── AquaSense Production Environment ──────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to git

# API Security key — change this to something secret
API_KEY=your-secret-key-here-change-this

# MongoDB (leave as-is for Docker, change for Atlas)
MONGODB_URI=mongodb://mongodb:27017/aquasense

# Frontend origin (your deployed URL or local)
FRONTEND_URL=http://localhost:3000

# ML Service
ML_SERVICE_URL=http://ml-service:8000

# Optional: MQTT broker (leave empty to disable)
MQTT_BROKER_URL=

# Alert thresholds (WHO drinking water standards)
DEFAULT_PH_MIN=6.5
DEFAULT_PH_MAX=8.5
DEFAULT_TURBIDITY_MAX=4.0
DEFAULT_TEMP_MIN=10
DEFAULT_TEMP_MAX=35
